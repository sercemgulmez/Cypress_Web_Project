{
  "name": "cypress-agentic-qa-ecommerce-framework",
  "version": "1.0.0",
  "description": "Production-safe Cypress QA automation framework for public e-commerce web flow testing.",
  "private": true,
  "scripts": {
    "test": "cypress run",
    "test:open": "cypress open",
    "test:chrome": "cypress run --browser chrome",
    "test:headed": "cypress run --headed",
    "test:smoke": "cypress run --spec 'cypress/e2e/homepage.cy.ts,cypress/e2e/search.cy.ts'",
    "cy:verify": "cypress verify"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "cypress": "^15.16.0",
    "typescript": "^5.8.3"
  }
}
